    {
      "name": "Agregar disponibilidad valida",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201 Created', function () { pm.response.to.have.status(201); });",
              "pm.test('Devuelve la disponibilidad creada', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.eql({ diaSemana: 'MARTES', horaDesde: '10:00', horaHasta: '13:00' });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"diaSemana\": \"MARTES\",\n  \"horaDesde\": \"10:00\",\n  \"horaHasta\": \"13:00\"\n}",
          "options": {
