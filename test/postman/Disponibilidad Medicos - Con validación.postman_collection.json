  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', function () { pm.response.to.have.status(200); });",
              "pm.test('Devuelve status UP', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('UP');",
              "  pm.expect(body).to.have.property('timestamp');",
              "  pm.expect(body).to.have.property('uptime');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Listar disponibilidades de medico existente",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', function () { pm.response.to.have.status(200); });",
              "pm.test('Devuelve una lista de disponibilidades', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.be.an('array');",
              "  pm.expect(body.length).to.be.greaterThan(0);",
              "  body.forEach((disponibilidad) => {",
              "    pm.expect(disponibilidad).to.have.property('diaSemana');",
              "    pm.expect(disponibilidad).to.have.property('horaDesde');",
              "    pm.expect(disponibilidad).to.have.property('horaHasta');",
              "  });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/medicos/{{medicoId}}/disponibilidades",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "medicos",
            "{{medicoId}}",
            "disponibilidades"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Listar disponibilidades de medico inexistente",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404 Not Found', function () { pm.response.to.have.status(404); });",
              "pm.test('Devuelve error MedicoNotFoundError', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.error).to.eql('MedicoNotFoundError');",
              "  pm.expect(body.message).to.include('no encontrado');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
